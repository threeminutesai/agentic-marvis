{
  "name": "agentic-marvis",
  "version": "0.5.2",
  "description": "Dashboard-oriented Marvis interface for bridging Codex and Claude Code",
  "author": "ThreeMinutesAI",
  "main": "src/main/main.js",
  "scripts": {
    "start": "chcp 65001 >nul & electron .",
    "test": "node --test \"tests/**/*.test.js\"",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "package:win-release": "powershell -ExecutionPolicy Bypass -File scripts/package-win-release.ps1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "26.1.0",
    "jsdom": "^24.0.0"
  },
  "dependencies": {},
  "build": {
    "appId": "ai.threeminutes.marvis",
    "productName": "Marvis",
    "copyright": "Copyright © ThreeMinutesAI",
    "files": [
      "src/**/*",
      "package.json",
      "data/music-library.json",
      "data/music/**/*",
      "skills/agentic-marvis-brief/**/*",
      "skills/agentic-marvis-dashboard/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
