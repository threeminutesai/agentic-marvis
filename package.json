{
  "name": "agentic-marvis",
  "version": "0.5.0",
  "description": "Dashboard-oriented Marvis interface for bridging Codex and Claude Code",
  "main": "src/main/main.js",
  "scripts": {
    "start": "chcp 65001 >nul & electron .",
    "test": "node --test \"tests/**/*.test.js\"",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "26.1.0",
    "jsdom": "^24.0.0"
  },
  "dependencies": {},
  "build": {
    "appId": "ai.threeminutes.marvis",
    "productName": "Marvis",
    "files": [
      "src/**/*",
      "package.json",
      "data/music/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
